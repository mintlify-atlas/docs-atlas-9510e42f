  "keyFeatures": [
    "Preemptive and cooperative multitasking scheduler",
    "Priority-based task scheduling with time slicing",
    "Multiple heap memory management implementations (heap_1 through heap_5)",
    "Queues, semaphores, and mutexes for inter-task communication",
    "Software timers with one-shot and auto-reload modes",
    "Event groups for synchronizing multiple tasks",
    "Stream buffers and message buffers for continuous data transfer",
    "Direct-to-task notifications for lightweight signaling",
    "Memory Protection Unit (MPU) support",
    "Symmetric Multiprocessing (SMP) support for multi-core targets",
    "Wide architecture support: ARM Cortex-M/R/A, RISC-V, AVR, PPC, x86 and more",
    "CMake FetchContent and git submodule integration"
  ],
  "publicApiSurface": [
    "xTaskCreate() / xTaskCreateStatic()",
    "vTaskDelete()",
    "vTaskDelay() / xTaskDelayUntil()",
    "vTaskSuspend() / vTaskResume()",
    "xTaskGetCurrentTaskHandle()",
    "uxTaskPriorityGet() / vTaskPrioritySet()",
    "xQueueCreate() / xQueueCreateStatic()",
    "xQueueSend() / xQueueReceive()",
    "xQueueSendFromISR() / xQueueReceiveFromISR()",
    "xSemaphoreCreateBinary() / xSemaphoreCreateMutex()",
    "xSemaphoreTake() / xSemaphoreGive()",
    "xSemaphoreTakeFromISR() / xSemaphoreGiveFromISR()",
    "xTimerCreate() / xTimerStart() / xTimerStop()",
    "xEventGroupCreate() / xEventGroupSetBits() / xEventGroupWaitBits()",
    "xStreamBufferCreate() / xStreamBufferSend() / xStreamBufferReceive()",
    "xMessageBufferCreate() / xMessageBufferSend() / xMessageBufferReceive()",
    "xTaskNotify() / xTaskNotifyWait() / xTaskNotifyFromISR()",
    "vTaskStartScheduler() / vTaskEndScheduler()",
    "taskENTER_CRITICAL() / taskEXIT_CRITICAL()",
    "portDISABLE_INTERRUPTS() / portENABLE_INTERRUPTS()"
  ]
